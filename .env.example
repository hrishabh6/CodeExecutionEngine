SERVER_PORT=8081
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_TIMEOUT=5000ms
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=leetcode
EXECUTION_BACKEND=worker-pod
EXECUTION_MODE=worker
WORKER_COUNT=5
EXECUTION_WORKER_QUEUE_CAPACITY=100
EXECUTION_TIMEOUT_SECONDS=10
EXECUTION_POLL_TIMEOUT_SECONDS=5
EXECUTION_MEMORY_SOFT_LIMIT_MB=256
EXECUTION_JAVA_COMPILE_COMMAND=javac
EXECUTION_JAVA_RUN_COMMAND=java
EXECUTION_PYTHON_RUN_COMMAND=python3
EXECUTION_COMPILATION_TIMEOUT_SECONDS=30
KUBERNETES_NAMESPACE=default
KUBERNETES_JOB_IMAGE=
KUBERNETES_JOB_IMAGE_PULL_POLICY=IfNotPresent
KUBERNETES_SERVICE_ACCOUNT_NAME=
KUBERNETES_JOB_ACTIVE_DEADLINE_SECONDS=30
KUBERNETES_JOB_COMPLETION_TIMEOUT_SECONDS=40
KUBERNETES_JOB_RESULT_POLL_INTERVAL_MILLIS=1000
KUBERNETES_JOB_RESULT_TTL_SECONDS=600
KUBERNETES_JOB_TTL_SECONDS_AFTER_FINISHED=120
KUBERNETES_JOB_DELETE_AFTER_READ=true
KUBERNETES_JOB_CPU_REQUEST=250m
KUBERNETES_JOB_MEMORY_REQUEST=256Mi
KUBERNETES_JOB_CPU_LIMIT=500m
KUBERNETES_JOB_MEMORY_LIMIT=256Mi
PROBLEM_SERVICE_URL=http://problem-service:8084
